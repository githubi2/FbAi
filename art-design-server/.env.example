# art-design-server 环境变量配置示例
# 复制此文件为 .env 并修改配置

# 数据库连接 (PostgreSQL)
# 格式: postgres://用户名:***@主机:端口/数据库名?sslmode=disable
DATABASE_URL=postgres://fbai:***@127.0.0.1:5432/fbai?sslmode=disable

# JWT 签名密钥（生产环境请修改）
JWT_SECRET=art-design-server-secret-key

# 服务端口
SERVER_PORT=:9090

# Gin 运行模式: debug | release | test
GIN_MODE=debug
